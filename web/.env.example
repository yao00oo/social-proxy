# 复制此文件为 .env.local，填入实际值
# 所有值找项目负责人要，不要自己瞎填

# PostgreSQL (Neon)
DATABASE_URL=postgresql://neondb_owner:xxx@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# NextAuth（注意：URL 只用 botook.ai，不要用 localhost）
NEXTAUTH_SECRET=用 openssl rand -base64 32 生成
NEXTAUTH_URL=https://botook.ai

# Google OAuth（回调地址只用 https://botook.ai/api/auth/callback/google）
GOOGLE_CLIENT_ID=找负责人要
GOOGLE_CLIENT_SECRET=找负责人要

# OpenRouter (AI 功能)
OPENROUTER_API_KEY=找负责人要
